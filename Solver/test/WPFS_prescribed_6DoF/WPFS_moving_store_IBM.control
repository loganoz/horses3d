/* Control file for a mesh-only wing+pylon smoke test */
Flow equations        = "NS"
mesh file name        = "MESH/WPFS_NoFins_background_mesh_hexas_g1_mesh.h5"

! Polynomial order      = 1
polynomial order file = "MESH/WPFS_store_pblocks.omesh"
Number of time steps  = 500000
Output Interval       = 1
autosave mode         = "iteration"
autosave interval     = 100

mach number           = 0.95d0
Reynolds number       = 9.972777d6
AOA theta             = 0.0d0
AOA phi               = 0.0d0
reference temperature (k) = 236.15d0

solution file name    = "RESULTS/WPFS_table_motion_p_adaption.hsol"
save gradients with solution = .false.
restart               = .false.  ! - The problem file already says the initial condition
restart file name     = "RESULTS/WPFS_steady_p2_0000430000.hsol"
restart polorder      = 2
Discretization nodes    = Gauss-Lobatto ! Gauss (Default) or Gauss-Lobatto
averaging               = Chandrasekar ! Only with split-form . Combined with Lax-Friedrichs high stability
inviscid discretization = Split-Form ! Standard (Default) of Split-Form
viscous discretization  = BR1 ! BR1, BR2(Default) or IP
riemann solver          = Lax-Friedrichs ! roe (less dissipative) or Lax-Friedrichs (more dissipative)

!-- Time integrator
simulation type       = time-accurate
time integration      = explicit
explicit method       = RK3
convergence tolerance = 1.0d-8
cfl                   = 0.50d0
dcfl                  = 0.50d0

partitioning          = SFC

!--STL
stl file name         = "MESH/store.stl"

#define IBM
  name = store
  active = .true.
  describe = .true.
  number of interpolation points = 15
  band region = .true.
  band region coefficient = 1.5
  compute distance = .true.
  clip axis = 0
  aab = .true.
#end

#define stlboundary store
  moving = .true.
  type = user-defined
#end

#define rigid motion frame store
  Type = prescribed table
  Reference center = [4.2618d0, -0.894d0, 3.3018d0] ! Obtained from StarCCM simulation (mesh). 
  Reference x axis = [1.0d0, 0.0d0, 0.0d0]
  Reference y axis = [0.0d0, 1.0d0, 0.0d0]
  Table file = "SETUP/prescribed_6dof_motion.csv"
  Angle units = degrees
  Rotation convention = ZYX
#end

#define boundary background.freestream
  type = FreeSlipWall
#end

#define boundary background.inlet
  type = Inflow
#end

#define boundary background.outlet
  type = Outflow
#end

#define boundary background.symmetry
  type = FreeSlipWall
#end

#define boundary wingpylon.wall
  type = NoSlipWall
#end

! -- #define surface monitor 1
! --   Name = drag
! --   Marker = wingpylon.wall
! --   Variable = drag
! --   Direction = [1.0d0, 0.0d0, 0.0d0]
! --   Reference surface = 1.0d0
! -- #end
! --
! -- #define surface monitor 2
! --   Name = lift
! --   Marker = wingpylon.wall
! --   Variable = lift
! --   Direction = [0.0d0, 1.0d0, 0.0d0]
! --   Reference surface = 1.0d0
