#define surface monitor 1
  Name = Fx_body
  Marker = store
  Variable = force
  Frame = store
  Direction = [1.0d0, 0.0d0, 0.0d0]
  Direction frame = body
#end

#define surface monitor 2
  Name = Fy_body
  Marker = store
  Variable = force
  Frame = store
  Direction = [0.0d0, 1.0d0, 0.0d0]
  Direction frame = body
#end

#define surface monitor 3
  Name = Fz_body
  Marker = store
  Variable = force
  Frame = store
  Direction = [0.0d0, 0.0d0, 1.0d0]
  Direction frame = body
#end

#define surface monitor 4
  Name = Mx_body
  Marker = store
  Variable = moment
  Frame = store
  Direction = [1.0d0, 0.0d0, 0.0d0]
  Direction frame = body
  CofR = [0.0d0, 0.0d0, 0.0d0]
  CofR frame = body
  Reference surface = 1.0d0
#end

#define surface monitor 5
  Name = My_body
  Marker = store
  Variable = moment
  Frame = store
  Direction = [0.0d0, 1.0d0, 0.0d0]
  Direction frame = body
  CofR = [0.0d0, 0.0d0, 0.0d0]
  CofR frame = body
  Reference surface = 1.0d0
#end

#define surface monitor 6
  Name = Mz_body
  Marker = store
  Variable = moment
  Frame = store
  Direction = [0.0d0, 0.0d0, 1.0d0]
  Direction frame = body
  CofR = [0.0d0, 0.0d0, 0.0d0]
  CofR frame = body
  Reference surface = 1.0d0
#end

! Export surfaces------------------------------
! Run one iteration once the simulation is converged
boundaries to save      = [wingpylon.wall, store] ! Solo superficie
slice z coordinates     = [0.1]
! slice z limits          = [-4000.0,6000.0,-1000,1000] ! si lo quiero todo, no poner limites
surface save timestep   = 2.2201125637404066E-02
surface save gradients  = .false.
surface save utau       = .true. ! Activar para Cf
surface save turbulent = .true. ! Activar para yplus
