/* Control file for the implicit Navier-Stokes solver */
Flow equations        = "NS"
mesh file name        = "MESH/CircleCombine_HO_NoSlidingBoundary.mesh"
mesh inner curves     = .TRUE.
Polynomial order      = 2! T2
Number of time steps  = 1000
Output Interval       = 10! for explicit
autosave mode         = "iteration"
autosave interval     = 500

Convergence tolerance = 1.d-8
cfl                   = 0.05d0
dcfl                  = 0.05d0
mach number            = 0.4d0
Reynolds number        = 20000.0d0

discretization nodes  = Gauss

solution file name    = "RESULTS/MMS.hsol"
save gradients with solution = .true.
restart               = .false.
restart file name     = "RESULTS/TMMS.hsol"
riemann solver         = "lax-friedrichs"
viscous discretization = "BR1"
!penalty parameter = 1.0
final time            = 40.d0
simulation type       = time-accurate
time integration      = explicit
multigrid levels      = 3
delta n = 1
mg sweeps exact = [1,1,1]
mg preconditioner = LTS ! for all runge kutta explicit

!-------------------------------------------------------------
! Inflow
!-------------------------------------------------------------

#define boundary Top
    type = user-defined
#end

#define boundary Bottom
    type = user-defined
#end

#define boundary Inner
    type = user-defined
#end
#define boundary Outer
    type = user-defined
#end

