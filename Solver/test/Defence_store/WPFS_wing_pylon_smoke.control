/* Control file for a mesh-only wing+pylon smoke test */
Flow equations        = "NS"
mesh file name        = "MESH/block_hex.msh"

Polynomial order      = 3
Number of time steps  = 500
Output Interval       = 50
autosave mode         = "iteration"
autosave interval     = 500

mach number           = 0.10d0
Reynolds number       = 1.0d6
AOA theta             = 0.0d0
AOA phi               = 0.0d0
reference temperature (k) = 293.0d0

solution file name    = "RESULTS/WPFS_store_smoke.hsol"
save gradients with solution = .false.
restart               = .false.
restart file name     = "RESULTS/WPFS_store_restart.hsol"
riemann solver        = "lax-friedrichs"
viscous discretization = "BR1"

simulation type       = steady-state
time integration      = explicit
convergence tolerance = 1.0d-8
cfl                   = 0.10d0
dcfl                  = 0.10d0

partitioning          = SFC

!--STL
stl file name         = "MESH/store.stl"

#define IBM
  name = store
  active = .true.
  describe = .true.
  number of interpolation points = 15
  band region = .true.
  band region coefficient = 1.5
  compute distance = .true.
  clip axis = 3
  aab = .true.
#end

#define stlboundary store
  type = NoSlipWall
#end

#define boundary xmin
  type = Inflow
#end

#define boundary xmax
  type = Outflow
#end

#define boundary ymin
  type = FreeSlipWall
#end

#define boundary ymax
  type = FreeSlipWall
#end

#define boundary zmin
  type = FreeSlipWall
#end

#define boundary zmax
  type = FreeSlipWall
#end

#define surface monitor 1
  Name = drag
  Marker = store
  Variable = drag
  Direction = [1.0d0, 0.0d0, 0.0d0]
  Reference surface = 1.0d0
#end

#define surface monitor 2
  Name = lift
  Marker = store
  Variable = lift
  Direction = [0.0d0, 1.0d0, 0.0d0]
  Reference surface = 1.0d0
#end
